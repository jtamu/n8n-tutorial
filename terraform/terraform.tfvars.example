# ============================================================
# GCP 設定
# GCP コンソール → プロジェクト設定 から取得
# ============================================================
gcp_project_id = "your-gcp-project-id"

# ============================================================
# リージョン (Always Free 対象: us-west1, us-central1, us-east1)
# ============================================================
gcp_region = "us-west1"
gcp_zone   = "us-west1-b"

# ============================================================
# SSH キー
# ============================================================
ssh_public_key_path = "~/.ssh/id_rsa.pub"
ssh_user            = "n8n"

# ============================================================
# n8n ドメイン (空 = IP 直アクセス、設定すると Caddy で自動 HTTPS)
# ============================================================
n8n_domain = ""
# n8n_domain = "n8n.example.com"

# ============================================================
# n8n 暗号化キー
# ============================================================
n8n_encryption_key = "CHANGE_ME"

# ============================================================
# IP アクセス制限 (空 = 全 IP 許可、設定すると指定 IP のみアクセス可)
# ============================================================
allowed_ips = []
# allowed_ips = ["203.0.113.10/32", "198.51.100.0/24"]

# ============================================================
# GitHub Actions 設定
# ============================================================
github_repo = "your-org/your-repo"

# ============================================================
# Cloudflare 設定
# Cloudflare ダッシュボード → jtamu.com → 概要 → ゾーン ID から取得
# API トークン: Cloudflare ダッシュボード → プロファイル → API トークン
#   権限: Zone - DNS - Edit
# ============================================================
cloudflare_api_token = "your-cloudflare-api-token"
cloudflare_zone_id   = "your-zone-id"
