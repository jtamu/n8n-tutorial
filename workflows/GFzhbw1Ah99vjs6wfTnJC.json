    {
      "parameters": {
        "jsCode": "const aiOutputs = $input.all();\nconst prepData = $('データ準備').all();\n\nconst results = [];\n\nfor (let i = 0; i < aiOutputs.length; i++) {\n  const output = aiOutputs[i].json.output;\n  if (!output || !output.evaluations) continue;\n\n  const prep = prepData[i].json;\n  let rowInfo;\n  try {\n    rowInfo = JSON.parse(prep._rowInfo);\n  } catch(e) {\n    continue;\n  }\n\n  for (const ev of output.evaluations) {\n    const match = rowInfo.find(r => r['評価対象'] === ev['評価対象']);\n    if (match) {\n      results.push({\n        json: {\n          'ID': match.ID,\n          '上長評価（グレード・ランク）': ev['上長評価（グレード・ランク）'],\n          '上長コメント（フィードバック）': ev['上長コメント（フィードバック）'],\n          '次期課題': ev['次期課題']\n        }\n      });\n    }\n  }\n}\n\nreturn results;"
      },
