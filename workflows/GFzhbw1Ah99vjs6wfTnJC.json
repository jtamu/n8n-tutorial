        "jsonSchemaExample": "{\n  \"evaluations\": [\n    {\n      \"評価対象\": \"総合\",\n      \"上長評価（グレード・ランク）\": \"G3 - Tech\",\n      \"上長コメント（フィードバック）\": \"コメント内容\",\n      \"次期課題\": \"- 課題1\\n- 課題2\"\n    },\n    {\n      \"評価対象\": \"A：テクニカルスキル\",\n      \"上長評価（グレード・ランク）\": \"G3 - Tech\",\n      \"上長コメント（フィードバック）\": \"コメント内容\",\n      \"次期課題\": \"- 課題1\\n- 課題2\"\n    },\n    {\n      \"評価対象\": \"B：ビジネススキル\",\n      \"上長評価（グレード・ランク）\": \"G3 - Tech\",\n      \"上長コメント（フィードバック）\": \"コメント内容\",\n      \"次期課題\": \"- 課題1\\n- 課題2\"\n    },\n    {\n      \"評価対象\": \"C：リーダーシップ/マネジメント\",\n      \"上長評価（グレード・ランク）\": \"G3 - Tech\",\n      \"上長コメント（フィードバック）\": \"コメント内容\",\n      \"次期課題\": \"- 課題1\\n- 課題2\"\n    }\n  ]\n}"
      },
