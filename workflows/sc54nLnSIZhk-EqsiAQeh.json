      "parameters": {
        "jsonSchemaExample": "{\n  \"中間上長フィードバック\": \"中間振り返りに対する上長フィードバック本文。振り返りが未記載の場合はnull\",\n  \"期末上長フィードバック\": \"期末振り返りに対する上長フィードバック本文。振り返りが未記載の場合はnull\"\n}"
      },
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        1520,
        272
      ],
      "id": "a1b20006-0006-4000-b000-000000000006",
      "name": "Structured Output Parser"
    },
    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output;\nconst fileId = $('データ統合').first().json._fileId;\n\nconst items = [];\n\nconst midFB = output['中間上長フィードバック'];\nif (midFB && midFB !== 'null' && String(midFB).trim()) {\n  items.push({\n    json: {\n      _fileId: fileId,\n      _cellRange: 'E31',\n      feedback: String(midFB)\n    }\n  });\n}\n\nconst endFB = output['期末上長フィードバック'];\nif (endFB && endFB !== 'null' && String(endFB).trim()) {\n  items.push({\n    json: {\n      _fileId: fileId,\n      _cellRange: 'E33',\n      feedback: String(endFB)\n    }\n  });\n}\n\nif (items.length === 0) {\n  throw new Error('フィードバックが生成されませんでした。');\n}\n\nreturn items;"
      },
