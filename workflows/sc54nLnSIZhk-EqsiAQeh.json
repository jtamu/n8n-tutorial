      "id": "874a06af-6d82-4df6-b69f-42d1b1dcdba0",
      "name": "YOKU評価シート取得",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "ZfwIn54p5eaFX5s0",
          "name": "Google Sheets account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// YOKU評価シートの全データ\nconst allRows = $('YOKU評価シート取得').all();\n\n// 社員情報\nconst employee = $('Filter').first().json;\nconst employeeName = employee['氏名'] || '対象社員';\n\n// ファイルID\nconst fileId = $('Search files and folders').first().json.id;\n\n// 目標行を抽出（row_number 26, 27, 28）\nconst goalRows = allRows.filter(r => [26, 27, 28].includes(r.json.row_number));\n\n// 目標をMarkdown化\nconst goalsMd = goalRows.map((g) => {\n  const d = g.json;\n  return [\n    '### 目標' + d.col_3,\n    '- **ミッション**: ' + (d.col_4 || '(未設定)'),\n    '- **プロセス**: ' + (d.col_6 || '(未設定)'),\n    '- **ゴール**: ' + (d.col_8 || '(未設定)')\n  ].join('\\n');\n}).join('\\n\\n');\n\n// 振り返りデータを抽出\n// 中間: col_14(ゴール振り返り), col_16(プロセス振り返り)\n// 期末: col_18(ゴール振り返り), col_20(プロセス振り返り)\nconst midTermReviews = goalRows.map(g => {\n  const d = g.json;\n  const parts = [];\n  if (d.col_14 && d.col_14.trim()) parts.push('【目標' + d.col_3 + ' ゴール振り返り】\\n' + d.col_14);\n  if (d.col_16 && d.col_16.trim()) parts.push('【目標' + d.col_3 + ' プロセス振り返り】\\n' + d.col_16);\n  return parts.join('\\n\\n');\n}).filter(s => s.trim()).join('\\n\\n');\n\nconst endTermReviews = goalRows.map(g => {\n  const d = g.json;\n  const parts = [];\n  if (d.col_18 && d.col_18.trim()) parts.push('【目標' + d.col_3 + ' ゴール振り返り】\\n' + d.col_18);\n  if (d.col_20 && d.col_20.trim()) parts.push('【目標' + d.col_3 + ' プロセス振り返り】\\n' + d.col_20);\n  return parts.join('\\n\\n');\n}).filter(s => s.trim()).join('\\n\\n');\n\n// フィードバック対象を判定\nconst feedbackTypes = [];\nif (midTermReviews.trim()) feedbackTypes.push('中間');\nif (endTermReviews.trim()) feedbackTypes.push('期末');\n\nif (feedbackTypes.length === 0) {\n  throw new Error('中間振り返りも期末振り返りも記載されていません。処理を中断します。');\n}\n\n// プロンプト組み立て\nconst sections = [\n  '以下の情報を基に、' + employeeName + 'さんへの上長フィードバックを生成してください。',\n  '',\n  '## ' + employeeName + 'さんの目標',\n  '',\n  goalsMd,\n  ''\n];\n\nif (midTermReviews.trim()) {\n  sections.push('## 中間振り返り（本人記載）');\n  sections.push('');\n  sections.push(midTermReviews);\n  sections.push('');\n}\n\nif (endTermReviews.trim()) {\n  sections.push('## 期末振り返り（本人記載）');\n  sections.push('');\n  sections.push(endTermReviews);\n  sections.push('');\n}\n\nsections.push('## 生成対象: ' + feedbackTypes.join('、') + 'の上長フィードバック');\n\nconst chatInput = sections.join('\\n');\n\nreturn [{ json: { chatInput, _fileId: fileId, _feedbackTypes: feedbackTypes } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1072,
        32
      ],
      "id": "a1b20003-0003-4000-b000-000000000003",
      "name": "データ統合"
    },
    {
      "parameters": {
        "hasOutputParser": true,
        "options": {
          "systemMessage": "あなたはエンジニアの上長（マネージャー）として、部下へのフィードバックを作成するエキスパートです。\n部下が設定した目標と、その振り返り内容を基に、建設的で具体的な上長フィードバックを生成してください。\n\n## フィードバックの方針\n- 部下の振り返りに対して、具体的な評価とアドバイスを記載する\n- 良かった点を認め、改善点を建設的に指摘する\n- 目標に対する達成度や進捗を客観的に評価する\n- 次のアクションにつながる具体的な助言を含める\n- ですます調で記述する（「である」「だ」ではなく「です」「ます」を使う）\n- 各フィードバックは200〜400文字程度で簡潔にまとめる\n\n## フォーマット\n- 話題の切り替わりや視点の切り替わりで適切に改行を入れ、読みやすい文章にすること\n- 例：「良かった点の評価」→改行→「改善点の指摘」→改行→「今後のアドバイス」のように構成する\n- 改行は\\nで表現すること\n\n## 中間フィードバックの場合\n- 半期の折り返し時点での進捗評価を行う\n- 残り半期に向けた方向性の確認と具体的なアドバイスを記載する\n- 目標達成に向けて軌道修正が必要な点があれば指摘する\n\n## 期末フィードバックの場合\n- 半期全体の成果を総合的に評価する\n- 目標に対する達成度を客観的に評価する\n- 次期に向けた課題・期待を記載する\n\n## 注意事項\n- 振り返りが記載されている種類のフィードバックのみを生成すること\n- 振り返りが記載されていない種類のフィードバックはnullとすること"
        }
      },
