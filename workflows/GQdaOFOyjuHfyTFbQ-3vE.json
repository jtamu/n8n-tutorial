        "jsonSchemaExample": "{\n  \"goals\": [\n    {\n      \"no\": 1,\n      \"category\": \"リレーション\",\n      \"mission\": \"ミッション内容\",\n      \"process\": \"- 行動計画1\\n- 行動計画2\\n- 行動計画3\",\n      \"goal\": \"- 達成基準1\\n- 達成基準2\"\n    },\n    {\n      \"no\": 2,\n      \"category\": \"ビジネス\",\n      \"mission\": \"ミッション内容\",\n      \"process\": \"- 行動計画1\\n- 行動計画2\\n- 行動計画3\",\n      \"goal\": \"- 達成基準1\\n- 達成基準2\"\n    },\n    {\n      \"no\": 3,\n      \"category\": \"エンジニアリング\",\n      \"mission\": \"ミッション内容\",\n      \"process\": \"- 行動計画1\\n- 行動計画2\\n- 行動計画3\",\n      \"goal\": \"- 達成基準1\\n- 達成基準2\"\n    }\n  ]\n}"
      },
