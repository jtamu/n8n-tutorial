    {
      "parameters": {
        "jsCode": "// Merge2で対象社員に絞り込み済みの評価データを取得\nconst evaluationData = $('Merge2').all();\nconst sampleSheet = $('YOKU評価シート取得').all();\nconst gradeTable = $('グレードテーブル取得').all();\n\n// 出力先ファイルIDを取得\nconst fileId = $('Search files and folders').first().json.id;\n\nif (evaluationData.length === 0) {\n  throw new Error('対象社員の評価データが見つかりませんでした');\n}\n\nconst employeeName = evaluationData[0].json['氏名'] || '対象社員';\nconst currentGrade = evaluationData[0].json['現状グレード・ランク'] || '';\n\n// --- 評価データをMarkdown化 ---\nconst skillCategories = ['A：テクニカルスキル', 'B：ビジネススキル', 'C：リーダーシップ/マネジメント'];\nconst evalSections = [];\n\nfor (const rec of evaluationData) {\n  const d = rec.json;\n  const subject = d['評価対象'] || '';\n  if (!skillCategories.some(c => subject.includes(c))) continue;\n\n  const section = [\n    '### ' + subject,\n    '',\n    '| 項目 | 内容 |',\n    '|---|---|',\n  ];\n  const addRow = (label, val) => {\n    if (val !== undefined && val !== null && val !== '' && val !== '(上長記入)' && val !== '(現場側入力)') {\n      section.push('| ' + label + ' | ' + String(val).replace(/\\n/g, '<br>') + ' |');\n    }\n  };\n  addRow('現場評価', d['現場評価（単価・顧客FB）']);\n  addRow('上長評価', d['上長評価（グレード・ランク）']);\n  addRow('上長コメント', d['上長コメント（フィードバック）']);\n  addRow('次期課題', d['次期課題']);\n  addRow('評価信頼度', d['評価信頼度']);\n  evalSections.push(section.join('\\n'));\n}\n\n// 総合の次期課題\nconst totalRec = evaluationData.find(r => r.json['評価対象'] === '総合');\nlet totalNextIssue = '';\nif (totalRec && totalRec.json['次期課題'] && totalRec.json['次期課題'] !== '(上長記入)') {\n  totalNextIssue = '### 総合の次期課題\\n\\n' + totalRec.json['次期課題'];\n}\n\n// 現場評価（総合）\nlet totalSiteEval = '';\nif (totalRec) {\n  const siteEval = totalRec.json['現場評価（単価・顧客FB）'] || '';\n  if (siteEval && siteEval !== '(現場側入力)') {\n    totalSiteEval = '### 現場評価（総合）\\n\\n' + siteEval;\n  }\n}\n\n// --- グレードテーブルをMarkdownテーブル化 ---\nconst gtHeader = ['| グレード | スキルレベル | ロール | 単価目安 | リレーション | ビジネス | エンジニアリング |', '|---|---|---|---|---|---|---|'];\nconst gtRows = gradeTable\n  .filter(r => r.json['グレード'] && r.json['グレード'] !== '-')\n  .map(r => {\n    const d = r.json;\n    const cell = (v) => String(v || '').replace(/\\n/g, '<br>');\n    return '| ' + [\n      cell(d['グレード']),\n      cell(d['スキルレベル']),\n      cell(d['ロール(現場)']),\n      cell(d['最低想定単価']),\n      cell(d['リレーションスキル（ポータブル）']),\n      cell(d['ビジネススキル（ポータブル）']),\n      cell(d['エンジニアリングスキル（ポータブル）'])\n    ].join(' | ') + ' |';\n  });\nconst gradeTableMd = gtHeader.concat(gtRows).join('\\n');\n\n// --- 評価シート参考をMarkdown化 ---\nconst sheetLines = [];\nfor (const row of sampleSheet) {\n  const d = row.json;\n  const label = d['対象期間'] || '';\n  const val = d['col_3'] || d['col_2'] || '';\n  if (!label && !val) continue;\n  if (val) {\n    sheetLines.push('- **' + label + '**: ' + String(val).replace(/\\n/g, '<br>'));\n  }\n}\nconst sheetRefMd = sheetLines.join('\\n');\n\n// --- chatInput 組み立て ---\nconst chatInput = [\n  '以下の情報を基に、' + employeeName + 'さんの次期目標を設定してください。',\n  '',\n  '## ' + employeeName + 'さんの基本情報',\n  '',\n  '- **現在のグレード**: ' + currentGrade,\n  '',\n  '## 前回評価の結果と次期課題',\n  '',\n  totalSiteEval,\n  '',\n  totalNextIssue,\n  '',\n  evalSections.join('\\n\\n'),\n  '',\n  '## グレードテーブル（次のグレードの要件参照）',\n  '',\n  gradeTableMd,\n  '',\n  '## 評価シート参考（キャリア・強み・課題・アクションプラン）',\n  '',\n  sheetRefMd,\n].join('\\n');\n\nreturn [{ json: { chatInput, _fileId: fileId } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1088,
