    {
      "parameters": {
        "jsCode": "// 評価管理から対象社員のデータをフィルタリング\nconst allEvaluation = $('評価管理フィルタ').all();\nconst employees = $('Filter').all();\nconst gradeTable = $('グレードテーブル取得').all().map(r => r.json);\n\n// フォームから対象年・対象期を取得\nconst formData = $('フォーム入力').first().json;\nconst targetYear = formData['対象年'];\nconst targetPeriod = formData['対象期'];\n\nconst results = [];\nfor (const emp of employees) {\n  const empNo = emp.json['社員番号'];\n  const hrFolderId = emp.json['人事フォルダID'];\n\n  // この社員の評価データを社員番号でフィルタ（対象年・対象期は評価管理フィルタノードで済み）\n  const evalData = allEvaluation\n    .filter(r => r.json['社員番号'] === empNo)\n    .map(r => r.json);\n\n  results.push({\n    json: {\n      evaluationData: evalData,\n      gradeTable: gradeTable,\n      hrFolderId: hrFolderId,\n      targetYear: targetYear,\n      targetPeriod: targetPeriod\n    }\n  });\n}\n\nreturn results;"
      },
