      "parameters": {
        "jsCode": "const output = $input.first().json.output;\nconst fileId = $input.first().json._fileId || $('\\u30c7\\u30fc\\u30bf\\u7d71\\u5408').first().json._fileId;\nconst goals = output.goals;\n\nreturn goals.map(g => ({\n  json: {\n    'No.': g.no,\n    'ミッション': g.mission,\n    'プロセス': g.process,\n    'ゴール': g.goal,\n    '_fileId': fileId\n  }\n}));"
