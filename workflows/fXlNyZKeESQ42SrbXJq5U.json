    {
      "parameters": {
        "jsCode": "const aiOutput = $('仮評価AI').first().json.output;\nconst gradeTable = $('グレードテーブル取得').all();\nconst context = $('コンテキスト統合').first().json;\nconst employee = $('社員ごとに処理').first().json;\nconst careerTrack = (employee['キャリアトラック'] || '').trim();\n\nconst skillLevels = {};\nfor (const skill of aiOutput.skills) {\n  skillLevels[skill.skill_name] = skill.level;\n}\n\nconst roleRow = gradeTable.find(r => r.json.row_number === 2);\nconst skillRows = gradeTable.filter(r => r.json.row_number > 2);\n\nfunction meetsRequirements(gradeCol) {\n  const unmet = [];\n  for (const row of skillRows) {\n    const skillName = row.json['グレード'];\n    const required = row.json[gradeCol];\n    if (required === 0) continue;\n    const actual = skillLevels[skillName];\n    if (actual === undefined || actual < required) {\n      unmet.push({ skill: skillName, required, actual: actual || 0 });\n    }\n  }\n  return { met: unmet.length === 0, unmet };\n}\n\nlet baseGrade = null;\nlet baseLabel = '';\nfor (const g of ['G1', 'G2']) {\n  const result = meetsRequirements(g);\n  if (result.met) {\n    baseGrade = g;\n    baseLabel = `${g} ${roleRow?.json[g] || ''}`.trim();\n  }\n}\n\nconst isBiz = careerTrack.toLowerCase() === 'biz';\nconst isTech = careerTrack.toLowerCase() === 'tech';\n\nlet bizGrade = baseGrade;\nlet bizLabel = baseLabel;\nlet bizUnmet = [];\nif (!isTech) {\n  for (const g of ['G3-Biz', 'G4-Biz', 'G5-Biz']) {\n    const result = meetsRequirements(g);\n    if (result.met) {\n      bizGrade = g;\n      bizLabel = `${g} ${roleRow?.json[g] || ''}`.trim();\n    } else {\n      bizUnmet = result.unmet;\n      break;\n    }\n  }\n}\n\nlet techGrade = baseGrade;\nlet techLabel = baseLabel;\nlet techUnmet = [];\nif (!isBiz) {\n  for (const g of ['G3-Tech', 'G4-Tech', 'G5-Tech']) {\n    const result = meetsRequirements(g);\n    if (result.met) {\n      techGrade = g;\n      techLabel = `${g} ${roleRow?.json[g] || ''}`.trim();\n    } else {\n      techUnmet = result.unmet;\n      break;\n    }\n  }\n}\n\nconst order = { 'G1': 1, 'G2': 2, 'G3-Biz': 3, 'G3-Tech': 3, 'G4-Biz': 4, 'G4-Tech': 4, 'G5-Biz': 5, 'G5-Tech': 5 };\nlet finalGrade, finalLabel, nextUnmet;\n\nif (isBiz) {\n  finalGrade = bizGrade;\n  finalLabel = bizLabel;\n  nextUnmet = bizUnmet;\n} else if (isTech) {\n  finalGrade = techGrade;\n  finalLabel = techLabel;\n  nextUnmet = techUnmet;\n} else {\n  if ((order[bizGrade] || 0) >= (order[techGrade] || 0)) {\n    finalGrade = bizGrade;\n    finalLabel = bizLabel;\n    nextUnmet = bizUnmet;\n  } else {\n    finalGrade = techGrade;\n    finalLabel = techLabel;\n    nextUnmet = techUnmet;\n  }\n}\n\nif (!finalGrade) {\n  finalLabel = 'G1未満';\n  nextUnmet = meetsRequirements('G1').unmet;\n}\n\nlet reason = `スキルレベル評価に基づき、${finalLabel}の全要件を満たしている。`;\nif (careerTrack) {\n  reason += ` (キャリアトラック: ${careerTrack})`;\n}\nif (nextUnmet.length > 0) {\n  const details = nextUnmet.map(s => `${s.skill}(要求Lv${s.required}/実際Lv${s.actual})`).join('、');\n  reason += `\\n次のグレードに未達のスキル: ${details}`;\n}\n\nreturn [{\n  json: {\n    grade: finalLabel,\n    reason_for_grade: reason,\n    confidence: aiOutput.confidence,\n    '社員番号': context['社員番号'],\n    '氏名': context['氏名']\n  }\n}];"
      },
